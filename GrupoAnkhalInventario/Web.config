	<system.web>
		<globalization culture="es-MX" uiCulture="es-MX" fileEncoding="utf-8" requestEncoding="utf-8" responseEncoding="utf-8"/>
		<customErrors mode="Off"/>
		<compilation debug="true" targetFramework="4.7.2" />
		<httpRuntime targetFramework="4.7.2" />

		<!-- Autenticación por formularios -->
		<authentication mode="Forms">
			<forms loginUrl="~/Login.aspx" defaultUrl="~/Default.aspx" timeout="60" slidingExpiration="true" />
		</authentication>

		<!-- Configuración de sesión -->
		<sessionState mode="InProc" timeout="60" />

		<machineKey validationKey="A2EFC3A388A9241FAB7A2B503F6C4C8F4526A06D8A2F0A400CE8DAF217D4E6E4B5E790184B2F32EC6A7F455CDE0B59008E5D978870F0E518E9F823762691B3F1" decryptionKey="AE5D7C883470D5BF41E8BE485D30227FB415CFCF3A5E2C6B" validation="SHA1" decryption="AES"/>
		<pages>
			<controls>
				<add tagPrefix="ajaxToolkit" assembly="AjaxControlToolkit" namespace="AjaxControlToolkit"/>
			</controls>
		</pages>
	</system.web>
	<system.codedom>
