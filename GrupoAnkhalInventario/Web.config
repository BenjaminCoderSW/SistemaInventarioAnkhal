	<appSettings>
		<!-- URL base de la API de empleados (sistema Asistencia) -->
		<!-- DEV local:   https://localhost:44325/api/usuarios  -->
		<!-- Producción:  https://grupoankhal.somee.com/api/usuarios  -->
